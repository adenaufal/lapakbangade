# ============================================================================
# LAPAKBANGADE LANDING PAGE - ENVIRONMENT VARIABLES REFERENCE
# ============================================================================
#
# HOW TO CHECK YOUR CONFIGURATION:
#   node scripts/check_env_vars.js          # Show all categories
#   node scripts/check_env_vars.js --strict # Validate CRITICAL vars only
#
# VARIABLES BY IMPORTANCE:
#   [CRITICAL]           - Required for authentication and API security
#   [HIGHLY RECOMMENDED] - Strongly suggested for production readiness
#   [OPTIONAL]           - Nice to have, service can still run without these
#
# SECURE VALUE GENERATION:
#   SESSION_SECRET:
#     node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   BACKEND_API_KEY:
#     node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
#
# CLOUDFLARE PAGES NOTE:
#   Set sensitive keys via Cloudflare Dashboard > Settings > Variables and Secrets.
#   Keep this file as documentation and local-development baseline.
#
# ============================================================================
# [CRITICAL] CORE SECURITY, AUTH, AND BACKEND ACCESS
# ============================================================================

# Session signing secret for Express and Cloudflare session verification.
SESSION_SECRET=replace_with_64_hex_chars

# Google OAuth credentials (used by auth.js and build/functions/auth/*).
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace_with_google_oauth_client_secret
GOOGLE_CALLBACK_URL=https://lapakbangade.com/auth/google/callback

# Backend API integration (lapakbangade-bot/admin API).
BACKEND_API_URL=https://admin.lapakbangade.com
BACKEND_API_KEY=replace_with_shared_api_key

# Cloudflare Functions backend base URL (used in build/functions/api/*).
API_URL=https://admin.lapakbangade.com

# ============================================================================
# [HIGHLY RECOMMENDED] PRODUCTION STABILITY AND SECURITY HARDENING
# ============================================================================

# Runtime environment.
NODE_ENV=production
PORT=3000

# Local Express proxy target (server.js); keep aligned with BACKEND_API_URL.
BOT_BACKEND_URL=https://admin.lapakbangade.com

# Exchange-rate API key for /api/rate (fallback is used if missing).
EXCHANGE_RATE_API_KEY=replace_with_exchangerate_api_key

# API rate limiting defaults for Cloudflare functions.
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_WINDOW_SECONDS=60

# Operational settings.
LOG_LEVEL=info
ALLOWED_ORIGINS=https://lapakbangade.com,https://www.lapakbangade.com

# ============================================================================
# [OPTIONAL] FEATURE FLAGS AND AUXILIARY SERVICES
# ============================================================================

# Optional Gemini integration (used by build/vite.config.ts if provided).
GEMINI_API_KEY=

# Optional override for fallback rate in custom deployments.
FALLBACK_BASE_RATE=16500

# Optional toggles for local debugging.
ENABLE_DEBUG_ROUTES=false
COOKIE_SECURE=true
